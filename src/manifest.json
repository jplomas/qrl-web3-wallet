{
  "manifest_version": 3,
  "minimum_chrome_version": "114",
  "name": "QRL Web3 Wallet",
  "description": "A web3 wallet that run on the QRL blockchain.",
  "icons": {
    "16": "icons/qrl/16.png",
    "24": "icons/qrl/24.png",
    "48": "icons/qrl/48.png",
    "64": "icons/qrl/64.png",
    "128": "icons/qrl/128.png"
  },
  "action": {
    "default_popup": "index.html",
    "default_title": "QRL Web3 Wallet",
    "default_icon": {
      "16": "icons/qrl/16.png",
      "128": "icons/qrl/128.png"
    }
  },
  "background": {
    "service_worker": "src/scripts/serviceWorker.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": ["src/scripts/contentScript.ts"],
      "matches": ["<all_urls>"],
      "all_frames": true
    }
  ],
  "permissions": [
    "alarms",
    "scripting",
    "tabs",
    "activeTab",
    "storage",
    "unlimitedStorage",
    "sidePanel",
    "notifications"
  ],
  "side_panel": {
    "default_path": "index.html"
  },
  "host_permissions": ["<all_urls>"]
}
